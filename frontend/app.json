{
  "expo": {
    "name": "GutAI",
    "slug": "gut-ai",
    "scheme": "gutai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "gut.ai",
      "buildNumber": "8",
      "infoPlist": {
        "NSCameraUsageDescription": "GutAI uses the camera to scan food barcodes",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.djapplications.gutai",
      "versionCode": 8,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "GutAI uses the camera to scan food barcodes"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "18ddbacc-5aee-4310-afba-96d053017225"
      },
      "router": {}
    },
    "owner": "thed24"
  }
}
